# Required environment variables — copy this to .env and fill in the values

# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (use URL-encoded special characters in password, e.g. @ → %40, # → %23)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
ADMIN_IDS=123456789,987654321
GROUP_CHAT_ID=-1001234567890

# Webhook — set to your public HTTPS URL (no trailing slash)
# Leave blank to use polling mode (local development)
WEBHOOK_URL=https://yourdomain.com
